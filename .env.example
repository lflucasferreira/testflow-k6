# TestFlow target
BASE_URL=http://localhost:5050

# Demo credentials (override in CI via secrets)
DEMO_EMAIL=demo@automation.io
DEMO_PASSWORD=Demo123!

# Active load profile: smoke | load | stress | spike | soak | breakpoint
