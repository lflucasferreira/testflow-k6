# TestFlow target
BASE_URL=http://localhost:5050

# Demo credentials (override in CI via secrets)
DEMO_EMAIL=demo@automation.io
DEMO_PASSWORD=Demo123!

# Active load profile: smoke | load | stress | spike | soak | breakpoint
K6_PROFILE=smoke

# Optional: service account for rules API (PATCH /api/users/:id)
SERVICE_CLIENT_ID=testflow-client
SERVICE_CLIENT_SECRET=testflow-secret

# --- InfluxDB output (K6_INFLUXDB=true) ---
# Target: auto (infer from addr) | local (Docker) | cloud (InfluxDB Cloud)
K6_INFLUXDB=false
K6_INFLUXDB_TARGET=auto

# Local Docker defaults (used when K6_INFLUXDB_TARGET=local)
K6_INFLUXDB_LOCAL_ADDR=http://influxdb:8086
K6_INFLUXDB_LOCAL_ORGANIZATION=testflow
K6_INFLUXDB_LOCAL_BUCKET=k6
K6_INFLUXDB_LOCAL_TOKEN=testflow-k6-dev-token
K6_INFLUXDB_LOCAL_INSECURE=true

# Cloud / auto — set in .env or copy .env.influx.cloud.example → .env.influx.cloud
K6_INFLUXDB_ORGANIZATION=testflow
K6_INFLUXDB_BUCKET=k6
K6_INFLUXDB_TOKEN=testflow-k6-dev-token
K6_INFLUXDB_ADDR=http://localhost:8086
K6_INFLUXDB_INSECURE=true
# K6_INFLUXDB_ADDR=https://us-east-1-1.aws.cloud2.influxdata.com
# K6_INFLUXDB_INSECURE=true
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=adminadmin
GRAFANA_PORT=3000
