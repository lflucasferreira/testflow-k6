# InfluxDB Cloud credentials (optional)
# Copy to .env.influx.cloud and fill in — loaded when K6_INFLUXDB_TARGET=cloud
# Do not commit .env.influx.cloud

K6_INFLUXDB_ADDR=https://us-east-1-1.aws.cloud2.influxdata.com
K6_INFLUXDB_ORGANIZATION=your-org-id-or-name
K6_INFLUXDB_BUCKET=k6
K6_INFLUXDB_TOKEN=your-influxdb-api-token
K6_INFLUXDB_INSECURE=true
